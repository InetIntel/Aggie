ENVIRONMENT=development


DATABASE_URL=
DATABASE_NAME=

# Admin Account 
ADMIN_EMAIL=
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_PARTY=false

# JWT Auth Configs
SECRET=
JWT_SESSION= # boolean

# WebAuthn Configs
RP_ID=      # domain, e.g. localhost for dev env
RP_NAME=    # name to identify server / application
ORIGIN=     # backend/public origin, e.g. http://localhost:8000 for dev env
APP_BASE_PATH= # backend subpath when deployed behind a prefix, 
MFA_REQUIRE_FOR_ENROLLED=   # boolean, controll organization-wide if mfa required once enrolled   

# AES-256 Encryption Key
ENCRYPTION_KEY=

# API Request Configs
API_REQUEST_TIMEOUT= 
API_FETCH_INTERVAL= 

# Web Socket Configs
SOCKET_FRONTEND_PORT=37778


PUBLIC_URL= # frontend public URL used by the React build



 
